{
  "schema_id": "restaurants_v1",
  "section_name": "Рестораны",
  "version": 1,
  "steps": [
    {
      "step_id": "residency_gate",
      "kind": "choice",
      "field_name": "resides_in_portugal",
      "prompt": "Вы или ваш бизнес находитесь в Португалии?",
      "required": true,
      "options": [
        {
          "value": "yes",
          "aliases": [
            "да",
            "yes",
            "y"
          ]
        },
        {
          "value": "no",
          "aliases": [
            "нет",
            "no",
            "n"
          ]
        }
      ],
      "stop_if_negative": true
    },
    {
      "step_id": "geo_tags",
      "kind": "choice",
      "field_name": "geo_tags",
      "prompt": "Выберите город, где работает ваш бизнес.\n\nМожно указать несколько городов через запятую или #online:",
      "options": [
        {
          "value": "lisboa",
          "label": "Lisboa"
        },
        {
          "value": "porto",
          "label": "Porto"
        },
        {
          "value": "coimbra",
          "label": "Coimbra"
        },
        {
          "value": "braga",
          "label": "Braga"
        },
        {
          "value": "faro",
          "label": "Faro"
        },
        {
          "value": "sintra",
          "label": "Sintra"
        },
        {
          "value": "cascais",
          "label": "Cascais"
        },
        {
          "value": "leiria",
          "label": "Leiria"
        },
        {
          "value": "madeira",
          "label": "Madeira"
        },
        {
          "value": "online",
          "label": "Онлайн"
        },
        {
          "value": "custom",
          "label": "Другие города"
        }
      ],
      "required": true,
      "validation": {
        "max_len": 200
      }
    },
    {
      "step_id": "description",
      "kind": "text",
      "field_name": "description",
      "prompt": "Опишите свои услуги, ассортимент, время работы и всё остальное, что вы считаете нужным сообщить потенциальным клиентам. \n\nПока не указывайте ни ссылки ни контакты, их можно будет добавить на следующих шагах.\n\nМаксимальная длина текста в этом блоке – 1.200 знаков:",
      "required": true,
      "validation": {
        "max_len": 1200
      }
    },
    {
      "step_id": "social_links",
      "kind": "text",
      "field_name": "social_links",
      "prompt": "Вставьте ссылки на соцсети или сайты вашего бизнеса, если они есть:",
      "required": false,
      "validation": {
        "max_len": 1200
      }
    },
    {
      "step_id": "telegram",
      "kind": "text",
      "field_name": "telegram",
      "prompt": "Укажите ваше имя пользователя в Telegram, начиная с @.",
      "required": true,
      "validation": {
        "max_len": 100
      }
    },
    {
      "step_id": "phone_main",
      "kind": "phone",
      "field_name": "phone_main",
      "prompt": "Укажите португальский номер телефона для основной связи, начиная с +351.",
      "required": true,
      "validation": {
        "regex": "^\\+351\\d{9}$"
      }
    },
    {
      "step_id": "phone_whatsapp",
      "kind": "phone",
      "field_name": "phone_whatsapp",
      "prompt": "Укажите номер телефона, к которому привязан WhatsApp для резервной связи, если отличается от основного. Можно оставить пустым.",
      "required": false,
      "validation": {
        "regex": "^\\+351\\d{9}$"
      }
    },
    {
      "step_id": "contact_name",
      "kind": "text",
      "field_name": "contact_name",
      "prompt": "Укажите название компании или имя представителя:",
      "required": true,
      "validation": {
        "max_len": 300
      }
    }
  ]
}
