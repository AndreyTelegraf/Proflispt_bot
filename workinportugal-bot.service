[Unit]
Description=Work in Portugal Telegram Bot
After=network.target

[Service]
Type=simple
User=bot
WorkingDirectory=/home/bot/workinportugal_bot
ExecStart=/usr/bin/python3 /home/bot/workinportugal_bot/main.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
